{
  "name": "@upstars-global/unity-ui",
  "version": "1.2.0",
  "type": "module",
  "license": "ISC",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "require": "./dist/components/*.cjs"
    },
    "./themes/alpa": {
      "types": "./dist/themes/alpa.d.ts",
      "import": "./dist/themes/alpa.js",
      "require": "./dist/themes/alpa.cjs"
    },
    "./themes/king": {
      "types": "./dist/themes/king.d.ts",
      "import": "./dist/themes/king.js",
      "require": "./dist/themes/king.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "deps:check": "depcruise src --config .dependency-cruiser.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "semantic-release",
    "chromatic": "npx chromatic",
    "prepublishOnly": "npm run test && npm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/vue3-vite": "^10.2.8",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.0",
    "chromatic": "^15.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-storybook": "^10.2.8",
    "eslint-plugin-vue": "^9.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.0",
    "semantic-release": "^24.0.0",
    "storybook": "^10.2.8",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.25",
    "vue-tsc": "^3.1.5"
  }
}